# Optional local overrides — nothing here is required for the default setup.
# Copy to .env and source it if you want non-default values.

# GCP
GCP_PROJECT_ID=quicklysign-terraform-dev
GCP_REGION=us-west1
GCP_ZONE=us-west1-a

# Coder CLI (set automatically by `coder login`; only needed for scripting)
# CODER_URL=https://coder.ragingbucket.com
# CODER_SESSION_TOKEN=   # create with: coder tokens create

# NEVER put Claude/Codex/GitHub credentials here or anywhere in this repo.
# They are entered interactively inside each workspace and persist on its disk:
#   claude                      (browser-code login over SSH)
#   codex login --device-auth
#   gh auth login
