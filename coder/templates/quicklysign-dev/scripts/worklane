#!/usr/bin/env bash
# worklane: jump into a work lane — cd to its repo, attach (or recreate) its
# tmux session, and show agent resume hints after a VM stop/start.
#
#   worklane trading-refactor
#   worklane                    # list known lanes
set -uo pipefail

SESSIONS_DIR="$HOME/.local/share/agent-sessions"

if [ "$#" -lt 1 ]; then
  echo "Usage: worklane <lane-name>"
  echo
  if ls "$SESSIONS_DIR"/*.json >/dev/null 2>&1; then
    echo "Known lanes:"
    for m in "$SESSIONS_DIR"/*.json; do
      printf "  %-22s %-7s %s\n" "$(jq -r .name "$m")" "$(jq -r .agent_type "$m")" "$(jq -r .repo_path "$m" | sed "s|^$HOME|~|")"
    done
  else
    echo "No lanes yet. Start one with: agent-run claude <lane> --repo ~/src/<repo>"
  fi
  exit 0
fi

LANE="$1"
META="$SESSIONS_DIR/$LANE.json"

REPO=""
AGENT=""
if [ -f "$META" ]; then
  REPO=$(jq -r '.repo_path // empty' "$META")
  AGENT=$(jq -r '.agent_type // empty' "$META")
elif [ -d "$HOME/lanes/$LANE" ]; then
  REPO="$HOME/lanes/$LANE" # multi-repo feature lane (see lane-init)
elif [ -d "$HOME/src/$LANE" ]; then
  REPO="$HOME/src/$LANE" # lane named after a repo: sensible default
fi

if [ -z "$REPO" ] || [ ! -d "$REPO" ]; then
  echo "Unknown lane '$LANE' (no metadata, and ~/src/$LANE does not exist)."
  echo "Run 'worklane' to list lanes, or 'agent-run <claude|codex> $LANE --repo <path>' to create it."
  exit 1
fi

if tmux has-session -t "=$LANE" 2>/dev/null; then
  exec tmux attach-session -t "=$LANE"
fi

# Session gone — i.e. the VM restarted. Reattaching starts a NEW work session,
# so reset the lane's TTL clock: the watchdog's TTL cap is measured from
# start_epoch, and that metadata persists on the disk across restarts. Without
# this, reattaching an old lane lands it past its cost-cap and the watchdog
# (the sole keeper under activity_bump=0) refuses to extend it. Reset to now.
if [ -f "$META" ] && command -v jq >/dev/null 2>&1; then
  now=$(date +%s); iso=$(date -u +%FT%TZ); tmp=$(mktemp)
  if jq --argjson n "$now" --arg iso "$iso" \
       '.start_epoch=$n | .start_time=$iso | .last_output_epoch=$n | .status="starting"' \
       "$META" >"$tmp" 2>/dev/null; then mv "$tmp" "$META"; else rm -f "$tmp"; fi
fi

# Create a fresh shell in the repo and surface the resume commands inside it.
HINTS="echo ''; echo 'Lane: $LANE (fresh session — the VM restarted)'"
case "$AGENT" in
  claude) HINTS+="; echo 'Resume Claude:  claude --continue   (or claude --resume to pick)'" ;;
  codex)  HINTS+="; echo 'Resume Codex:   codex resume --last'" ;;
  *)      HINTS+="; echo 'Resume:  claude --continue   or   codex resume --last'" ;;
esac
HINTS+="; echo ''"

tmux new-session -d -s "$LANE" -c "$REPO"
tmux send-keys -t "=$LANE:" "clear; $HINTS" Enter
exec tmux attach-session -t "=$LANE"
